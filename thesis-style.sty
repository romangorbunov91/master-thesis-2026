% thesis-style.sty
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{thesis-style}[2026/04/25 ITMO Master's Thesis Style]

% --- Metadata commands ---
\newcommand{\universityName}[1]{\gdef\@universityName{#1}}
\newcommand{\universityFaculty}[1]{\gdef\@universityFaculty{#1}}
\newcommand{\studyProgramm}[1]{\gdef\@studyProgramm{#1}}
\newcommand{\documentName}[1]{\gdef\@documentName{#1}}
\newcommand{\thesisTitle}[1]{\gdef\@thesisTitle{#1}}
\newcommand{\studentName}[1]{\gdef\@studentName{#1}}
\newcommand{\advisorName}[1]{\gdef\@advisorName{#1}}
\newcommand{\universityCity}[1]{\gdef\@universityCity{#1}}
\newcommand{\releaseYear}[1]{\gdef\@releaseYear{#1}}

% Default values (can be overridden in main.tex)
\def\@universityName{}
\def\@universityFaculty{}
\def\@studyProgramm{}
\def\@documentName{}
\def\@thesisTitle{}
\def\@studentName{}
\def\@universityCity{}
\def\@releaseYear{}
\def\@advisorName{}

% --- Custom Title Page ---
\newcommand{\makeThesisTitle}{%
  \begin{titlepage}
    \singlespacing
    \centering
    
    \large \textbf{\@universityName} \\[0.5cm]
    \normalsize \@universityFaculty \\[8.0cm]
    
    \large \textbf{\@documentName} \\[0.0cm]
    \normalsize по направлению подготовки \\
    \textbf{\@studyProgramm} \\[1.5cm]
    \large Тема: \textbf{\@thesisTitle} \\[3.0cm]

    \normalsize
    \begin{tabular}{l@{\hspace{-10.5em}}l}
      \textbf{Выполнил:} \@studentName \\
      \textbf{Научный руководитель:} \@advisorName
    \end{tabular}

    \vfill
    \fontsize{14pt}{17pt}\selectfont\@universityCity, \@releaseYear
  \end{titlepage}%
  \thispagestyle{empty}%
}

% Unnumbered chapter with TOC entry.
\newcommand{\unnumberedChapter}[2][chapter]{%
  \chapter*{#2}%
  \addcontentsline{toc}{#1}{#2}%
}

% --- Chapter spacing & formatting ---
\titlespacing*{\chapter}
  {0pt}   % left
  {0pt}  % top (reduce to shrink gap)
  {18pt}  % bottom

\endinput